[Desktop Entry]
Version=1.0
Name=Teams
Exec=google-chrome-stable --app=https://teams.microsoft.com/v2/ --name=Teams --class=Teams
Terminal=False
Type=Application
# Annoyingly, fuzzel doesn't seem to expand shell variables so $HOME or $USER don't work here - have to hardcode the username :(
Icon=/home/alex/.local/share/applications/icons/Teams.png
Categories=GTK;
MimeType=text/html;text/xml;application/xhtml_xml;
StartupNotify=true
