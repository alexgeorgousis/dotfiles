# Ignore autogenerated fish files
# All my custom config is in ~/.config/fish/conf.d/ with the exception of some plugins (e.g. autopair.fish) which seems to have snuck their files in there (which is annoying, might wanna look into that).
.config/fish/*
!.config/fish/conf.d/
!.config/fish/conf.d/**
!.config/fish/config.fish
.config/fish/conf.d/autopair.fish

# Ignore config of programs I don't want to configure
.config/spotify/*
.config/google-chrome/*
.config/BraveSoftware/*
.config/kwalletrc
.config/dconf/*
.config/go/*
.config/lazygit/*
.config/mimeapps.list
.config/pavucontrol.ini
.config/kde.org/*
.config/nvim/lazy-lock.json
.config/systemd/*
.config/pulse/*
.config/htop/*
.config/QtProject.conf
.config/GIMP/*
.config/github-copilot/*
.config/session/*
.config/baloofileinformationrc
.aws/*
.Microsoft/*
.cisco/*
.config/Code/*
.config/Pop/*
.config/Slack/*
.config/cengtools/*
.config/gcloud/*
.config/gh/*
.config/.gsd-keyboard.settings-ported
.config/environment.d/*
.config/evolution/*
.config/fontconfig/*
.config/glib-2.0/*
.config/gnome-initial-setup-done
.config/gtk-3.0/*
.config/ibus/*
.config/intune/*
.config/jgit/*
