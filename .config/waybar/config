{
  "layer": "top",
  "position": "top",
  "modules-left": ["custom/bluetooth"],
  "modules-right": ["clock"],

  "custom/bluetooth": {
    "exec": "~/.config/waybar/scripts/bluetooth.sh",
    "interval": 10,
    "return-type": "json",
    "on-click": "blueman-manager"
  },

  "clock": {
    "format": "  {:%d-%m-%Y %H:%M:%S}"
  }
}
